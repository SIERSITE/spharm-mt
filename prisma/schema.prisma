generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UtilizadorPerfil {
  ADMINISTRADOR
  GESTOR_GRUPO
  GESTOR_FARMACIA
  OPERADOR
}

enum EntidadeEstado {
  ATIVO
  INATIVO
}

enum ProdutoEstado {
  NOVO
  PENDENTE
  PARCIALMENTE_ENRIQUECIDO
  ENRIQUECIDO_AUTOMATICAMENTE
  VALIDADO
  INATIVO
}

enum ProdutoOrigemDados {
  EXCEL
  FARMACIA
  ENRIQUECIMENTO
  MANUAL
}

enum FornecedorTipo {
  COOPERATIVA
  LABORATORIO_DIRETO
  DISTRIBUIDOR
  OUTRO
}

enum TipoClassificacao {
  NIVEL_1
  NIVEL_2
}

enum TipoVenda {
  RECEITA
  SEM_RECEITA
  VENDA_LIVRE
  OUTRO
}

enum TipoDevolucao {
  CLIENTE
  FORNECEDOR
  OUTRA
}

enum PrioridadeRevisao {
  ALTA
  MEDIA
  BAIXA
}

enum EstadoFilaRevisao {
  PENDENTE
  RESOLVIDO
  IGNORADO
}

enum TipoRevisao {
  NOVO_PRODUTO
  ENRIQUECIMENTO_FALHOU
  CONFLITO
  CLASSIFICACAO_PENDENTE
  FABRICANTE_PENDENTE
  OUTRO
}

enum EstadoListaEncomenda {
  RASCUNHO
  FINALIZADA
  EXPORTADA
}

/// Estado do fluxo outbound de exportação de uma lista de encomenda
/// para a instância SPharm da farmácia. Distinto de EstadoListaEncomenda:
/// aquele é a fase de negócio (rascunho → finalizada → exportada); este
/// é o sub-estado da máquina de outbox dentro da fase "finalizada".
///
/// Transições válidas:
///   PENDENTE      → EM_EXPORTACAO  (agent claimed lease)
///   EM_EXPORTACAO → EXPORTADO      (agent confirmed write via ack)
///   EM_EXPORTACAO → PENDENTE       (nack retryable, schedule next attempt)
///   EM_EXPORTACAO → FALHADO        (nack non-retryable OR max attempts)
///   FALHADO       → PENDENTE       (manual re-send via /retry endpoint)
///   PENDENTE      → CANCELADO      (admin cancel antes da exportação)
///   FALHADO       → CANCELADO      (admin desiste de re-tentar)
enum OrderExportState {
  PENDENTE
  EM_EXPORTACAO
  EXPORTADO
  FALHADO
  CANCELADO
}

enum TipoLoteIngestao {
  FICHA
  STOCK
  VENDAS
  VENDAS_MENSAIS
  COMPRAS
  DEVOLUCOES
  AJUSTES_STOCK
  INVENTARIO
  PRODUTOS_INTERNOS
}

enum EstadoLoteIngestao {
  RECEBIDO
  EM_PROCESSAMENTO
  PROCESSADO
  FALHOU
}

enum ClassificacaoRotacao {
  NORMAL
  ATENCAO
  SEM_ROTACAO
}

enum ClassificacaoABC {
  A
  B
  C
  NAO_CLASSIFICADO
}

enum EnriquecimentoEstado {
  PENDENTE
  EM_PROCESSAMENTO
  SUCESSO
  SUCESSO_PARCIAL
  FALHOU
}

enum VerificationStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  PARTIALLY_VERIFIED
  FAILED
  NEEDS_REVIEW
}

enum TipoAjusteStock {
  POSITIVO
  NEGATIVO
  CORRECAO
  QUEBRA
  PERDA
  OUTRO
}

enum EstadoInventario {
  RASCUNHO
  FECHADO
  PROCESSADO
  CANCELADO
}

//////////////////////////////////////////////////////
// CATÁLOGO CENTRAL
//////////////////////////////////////////////////////

/// Produto global do grupo, identificado por CNP.
model Produto {
  id                    String               @id @default(cuid())
  cnp                   Int                  @unique
  designacao            String
  fabricanteId          String?
  classificacaoNivel1Id String?
  classificacaoNivel2Id String?
  tipoArtigo            String?
  codigoATC             String?
  dci                   String?
  imagemUrl             String?
  formaFarmaceutica     String?
  dosagem               String?
  embalagem             String?
  flagGenerico          Boolean              @default(false)
  flagMSRM              Boolean              @default(false)
  flagMNSRM             Boolean              @default(false)
  grupoHomogeneo        String?
  estado                ProdutoEstado        @default(PENDENTE)
  origemDados           ProdutoOrigemDados   @default(FARMACIA)
  validadoManualmente          Boolean              @default(false)
  // Classificação e verificação automática
  productType                  String?
  productTypeConfidence        Float?
  classificationSource         String?
  classificationVersion        String?
  verificationStatus           VerificationStatus   @default(PENDING)
  lastVerifiedAt               DateTime?
  lastVerificationAttemptAt    DateTime?
  externallyVerified           Boolean              @default(false)
  needsManualReview            Boolean              @default(false)
  manualReviewReason           String?
  dataCriacao                  DateTime             @default(now())
  dataAtualizacao              DateTime             @updatedAt

  fabricante                   Fabricante?          @relation(fields: [fabricanteId], references: [id])
  classificacaoNivel1          Classificacao?       @relation("ProdutoClassificacaoNivel1", fields: [classificacaoNivel1Id], references: [id])
  classificacaoNivel2          Classificacao?       @relation("ProdutoClassificacaoNivel2", fields: [classificacaoNivel2Id], references: [id])

  produtosFarmacia             ProdutoFarmacia[]
  vendas                       Venda[]
  vendasMensais                VendaMensal[]
  compras                      Compra[]
  devolucoes                   Devolucao[]
  historicoStocks              HistoricoStock[]
  ajustesStock                 AjusteStock[]
  linhasInventario             LinhaInventario[]
  indicadores                  IndicadoresProdutoFarmacia[]
  linhasEncomenda              LinhaEncomenda[]
  filaRevisao                  FilaRevisao[]
  filaEnriquecimento           EnriquecimentoFila[]
  verificacaoHistorico         ProdutoVerificacaoHistorico[]
  enrichmentSourceLogs         EnrichmentSourceLog[]

  @@index([fabricanteId])
  @@index([classificacaoNivel1Id])
  @@index([classificacaoNivel2Id])
  @@index([estado])
  @@index([verificationStatus])
  @@index([productType])
  @@index([lastVerifiedAt])
}

/// Fabricante normalizado.
model Fabricante {
  id              String            @id @default(cuid())
  nomeNormalizado String            @unique
  paisOrigem      String?
  estado          EntidadeEstado    @default(ATIVO)
  dataCriacao     DateTime          @default(now())
  dataAtualizacao DateTime          @updatedAt

  aliases         FabricanteAlias[]
  produtos        Produto[]
}

/// Variantes de nomes de fabricante encontradas nas origens.
model FabricanteAlias {
  id            String      @id @default(cuid())
  fabricanteId  String
  aliasNome     String

  fabricante    Fabricante  @relation(fields: [fabricanteId], references: [id], onDelete: Cascade)

  @@unique([fabricanteId, aliasNome])
  @@index([aliasNome])
}

/// Árvore de classificação central.
model Classificacao {
  id                 String               @id @default(cuid())
  nome               String
  tipo               TipoClassificacao
  classificacaoPaiId String?
  estado             EntidadeEstado       @default(ATIVO)
  ordem              Int?
  dataCriacao        DateTime             @default(now())
  dataAtualizacao    DateTime             @updatedAt

  classificacaoPai   Classificacao?       @relation("ClassificacaoPaiFilho", fields: [classificacaoPaiId], references: [id])
  subClassificacoes  Classificacao[]      @relation("ClassificacaoPaiFilho")

  produtosNivel1     Produto[]            @relation("ProdutoClassificacaoNivel1")
  produtosNivel2     Produto[]            @relation("ProdutoClassificacaoNivel2")

  @@unique([nome, tipo, classificacaoPaiId])
  @@index([tipo])
  @@index([classificacaoPaiId])
}

/// Snapshot local do catálogo INFARMED de medicamentos (Portugal).
///
/// Origem: ficheiro descarregado do portal INFARMED (INFOMED / Open Data).
/// Importado por scripts/import-infarmed-snapshot.ts, idempotente por CNP.
///
/// Consultado pelo infarmedConnector em lib/catalog-connectors.ts,
/// que devolve tier=REGULATORY e confidence=0.95 quando há match por CNP.
/// É a primeira fonte autoritária para escrever Produto.fabricanteId / dci / codigoATC.
model InfarmedSnapshot {
  id                String   @id @default(cuid())
  cnp               Int      @unique
  designacaoOficial String
  dci               String?
  codigoATC         String?
  /// Titular da Autorização de Introdução no Mercado — fabricante canónico.
  titularAim        String?
  formaFarmaceutica String?
  dosagem           String?
  embalagem         String?
  grupoTerapeutico  String?
  /// Estado regulamentar: "Autorizado", "Suspenso", "Revogado", "Caducado".
  /// Produtos não-"Autorizado" não são devolvidos pelo conector.
  estadoAim         String?
  /// Identificador do ficheiro/data do snapshot (ex: "2026-04"). Permite
  /// detectar quando uma reimportação trouxe dados mais recentes.
  snapshotVersion   String
  importedAt        DateTime @default(now())

  @@index([snapshotVersion])
  @@index([estadoAim])
}

/// Histórico de verificações automáticas por produto.
model ProdutoVerificacaoHistorico {
  id                 String   @id @default(cuid())
  produtoId          String
  verificadoEm       DateTime @default(now())
  productType        String?
  productTypeConf    Float?
  verificationStatus String
  sourceSummary      Json?
  fieldsUpdated      String[]

  produto            Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId, verificadoEm])
}

/// Resultado de cada chamada a um conector externo.
///
/// Granularidade: uma row por (produto × conector × tentativa) — alimenta
/// as métricas de qualidade de fonte em /admin/catalogo. Nunca lido pelo
/// pipeline em runtime; é só observabilidade.
///
/// Status:
///   SUCCESS   — o conector devolveu ExternalSourceData não-null.
///   NO_MATCH  — o conector devolveu null (sem dados para este CNP/designação).
///   ERROR     — o conector lançou (timeout, HTTP error, parse fail). A mensagem
///               é capturada em errorMessage truncada a 500 chars.
///
/// Append-only. Não há UPDATE; reverify gera nova row.
model EnrichmentSourceLog {
  id              String                  @id @default(cuid())
  produtoId       String
  source          String
  status          EnrichmentSourceStatus
  /// Confiança devolvida pela fonte para este produto. Só preenchido em SUCCESS.
  confidence      Float?
  /// "cnp" | "designacao" | "ean" | "unknown" — como o conector encontrou o produto.
  matchedBy       String?
  durationMs      Int?
  /// Lista de campos não-null devolvidos pela fonte (fabricante, atc, categoria, …).
  /// Só preenchido em SUCCESS. Permite contar coverage por campo por fonte.
  fieldsReturned  String[]
  errorMessage    String?
  createdAt       DateTime                @default(now())

  produto         Produto                 @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([source, createdAt])
  @@index([produtoId, createdAt])
  @@index([status, createdAt])
}

enum EnrichmentSourceStatus {
  SUCCESS
  NO_MATCH
  ERROR
}

/// Fornecedor normalizado.
model Fornecedor {
  id                        String                         @id @default(cuid())
  nomeNormalizado           String                         @unique
  tipo                      FornecedorTipo                 @default(OUTRO)
  estado                    EntidadeEstado                 @default(ATIVO)
  dataCriacao               DateTime                       @default(now())
  dataAtualizacao           DateTime                       @updatedAt

  aliases                   FornecedorAlias[]
  produtosFarmacia          ProdutoFarmacia[]
  compras                   Compra[]                       @relation("CompraFornecedor")
  devolucoesDestino         Devolucao[]                    @relation("DevolucaoFornecedorDestino")
  indicadoresUltimoFornecedor IndicadoresProdutoFarmacia[] @relation("IndicadorUltimoFornecedor")
  linhasEncomenda           LinhaEncomenda[]               @relation("LinhaEncomendaFornecedorSugerido")
}

/// Variantes de nomes de fornecedor.
model FornecedorAlias {
  id            String      @id @default(cuid())
  fornecedorId  String
  aliasNome     String

  fornecedor    Fornecedor  @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  @@unique([fornecedorId, aliasNome])
  @@index([aliasNome])
}

//////////////////////////////////////////////////////
// ESTRUTURA MULTI-FARMÁCIA
//////////////////////////////////////////////////////

model Farmacia {
  id               String                     @id @default(cuid())
  nome             String
  codigoANF        String?
  morada           String?
  contacto         String?
  estado           EntidadeEstado             @default(ATIVO)
  dataAdesao       DateTime                   @default(now())
  dataCriacao      DateTime                   @default(now())
  dataAtualizacao  DateTime                   @updatedAt

  utilizadores     Utilizador[]
  utilizadoresExtra UtilizadorFarmacia[]
  produtosFarmacia ProdutoFarmacia[]
  produtosInternos ProdutoInterno[]
  vendas           Venda[]
  vendasMensais    VendaMensal[]
  compras          Compra[]
  devolucoes       Devolucao[]
  historicoStocks  HistoricoStock[]
  ajustesStock     AjusteStock[]
  inventarios      Inventario[]
  indicadores      IndicadoresProdutoFarmacia[]
  listasEncomenda  ListaEncomenda[]
  lotesIngestao    LoteIngestao[]
  emailConfig      EmailConfig?

  @@unique([nome])
  @@index([codigoANF])
}

// Configuração SMTP por farmácia. Quando farmaciaId é null, é a
// configuração global usada como fallback. A password é guardada
// cifrada (AES-256-GCM) — ver lib/email-crypto.ts.
model EmailConfig {
  id                String    @id @default(cuid())
  farmaciaId        String?   @unique
  farmacia          Farmacia? @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  smtpHost          String
  smtpPort          Int
  smtpUser          String?
  smtpPassEncrypted String?
  smtpSecure        Boolean   @default(false)
  fromEmail         String
  fromName          String?
  replyTo           String?
  isActive          Boolean   @default(true)
  lastTestAt        DateTime?
  lastTestStatus    String?
  lastTestError     String?
  dataCriacao       DateTime  @default(now())
  dataAtualizacao   DateTime  @updatedAt
}

model Utilizador {
  id              String             @id @default(cuid())
  email           String             @unique
  nome            String
  perfil          UtilizadorPerfil
  /// Farmácia PRIMÁRIA (contexto por defeito para sessão e filtros).
  /// Para GESTOR_GRUPO/ADMINISTRADOR é opcional. Para acesso a várias
  /// farmácias usar a relação `farmacias` (UtilizadorFarmacia).
  farmaciaId      String?
  estado          EntidadeEstado     @default(ATIVO)
  passwordHash    String?
  /// Marca o próximo login como forçado a alterar a password (ex:
  /// reset administrativo). A API /login vai validar e redirigir.
  mustChangePassword Boolean         @default(false)
  ultimoLogin     DateTime?
  dataCriacao     DateTime           @default(now())
  dataAtualizacao DateTime           @updatedAt

  farmacia        Farmacia?          @relation(fields: [farmaciaId], references: [id])
  farmacias       UtilizadorFarmacia[]
  listasEncomenda ListaEncomenda[]
  auditoria       AuditLog[]         @relation("AuditLogActor")
}

/// Associação N:N utilizador → farmácias para perfis com acesso a
/// múltiplas (ex: GESTOR_GRUPO, GESTOR_FARMACIA com mais do que uma).
/// Pode ser ignorado quando `Utilizador.perfil = ADMINISTRADOR`, que
/// por contrato tem acesso a TODAS as farmácias.
model UtilizadorFarmacia {
  id            String     @id @default(cuid())
  utilizadorId  String
  farmaciaId    String
  dataCriacao   DateTime   @default(now())

  utilizador    Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  farmacia      Farmacia   @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)

  @@unique([utilizadorId, farmaciaId])
  @@index([farmaciaId])
}

/// Auditoria básica — regista acções relevantes do utilizador.
/// Fica propositadamente genérico (string action + JSON meta) para
/// não acoplar a um domínio específico. Chamar `logAudit(...)` do
/// server-side quando uma acção precisa ser rastreável.
model AuditLog {
  id           String     @id @default(cuid())
  actorId      String?
  action       String
  entity       String?
  entityId     String?
  metaJson     String?
  ip           String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  actor        Utilizador? @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
}

//////////////////////////////////////////////////////
// PRODUTO POR FARMÁCIA
//////////////////////////////////////////////////////

/// Tudo o que varia entre farmácias vive aqui.
model ProdutoFarmacia {
  id                   String        @id @default(cuid())
  produtoId            String
  farmaciaId           String
  designacaoLocal      String?
  pvp                  Decimal?      @db.Decimal(12, 4)
  pmc                  Decimal?      @db.Decimal(12, 4)
  puc                  Decimal?      @db.Decimal(12, 4)
  stockAtual           Decimal?      @db.Decimal(14, 3)
  stockRaw             Decimal?      @db.Decimal(14, 3)
  stockMinimo          Decimal?      @db.Decimal(14, 3)
  stockMaximo          Decimal?      @db.Decimal(14, 3)
  fornecedorHabitualId String?
  dataUltimaVenda      DateTime?
  dataUltimaCompra     DateTime?
  validadeMaisAntiga   DateTime?
  flagRetirado         Boolean       @default(false)
  modeloGestaoStock    String?
  familiaOrigem        String?
  categoriaOrigem      String?
  subcategoriaOrigem   String?
  /// Fornecedor/distribuidor habitual da farmácia (NÃO é o fabricante real
  /// do produto — é o grossista que vende o produto à farmácia: Empifarma,
  /// OCP, Alliance, etc.). Usado apenas como contexto interno, análise de
  /// abastecimento e hints fracos. NUNCA como fabricante canónico.
  fornecedorOrigem     String?
  dataAtualizacao      DateTime      @updatedAt
  dataCriacao          DateTime      @default(now())

  produto              Produto       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  farmacia             Farmacia      @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  fornecedorHabitual   Fornecedor?   @relation(fields: [fornecedorHabitualId], references: [id])

  @@unique([produtoId, farmaciaId])
  @@index([farmaciaId])
  @@index([produtoId])
  @@index([fornecedorHabitualId])
  @@index([flagRetirado])
}

//////////////////////////////////////////////////////
// PRODUTOS INTERNOS
//////////////////////////////////////////////////////

/// Produtos internos/localizados apenas na farmácia.
model ProdutoInterno {
  id              String        @id @default(cuid())
  farmaciaId      String
  codigoInterno   Int
  designacao      String?
  tipoArtigo      String?
  pvp             Decimal?      @db.Decimal(12, 4)
  puc             Decimal?      @db.Decimal(12, 4)
  stockAtual      Decimal?      @db.Decimal(14, 3)
  flagRetirado    Boolean       @default(false)
  dataCriacao     DateTime      @default(now())
  dataAtualizacao DateTime      @updatedAt
  loteIngestaoId  String?

  farmacia        Farmacia      @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  loteIngestao    LoteIngestao? @relation(fields: [loteIngestaoId], references: [id])

  ajustesStock    AjusteStock[]
  linhasInventario LinhaInventario[]

  @@unique([farmaciaId, codigoInterno])
  @@index([farmaciaId])
  @@index([codigoInterno])
}

//////////////////////////////////////////////////////
// DADOS TRANSACIONAIS
//////////////////////////////////////////////////////

/// Vendas diárias agregadas por produto-dia-farmácia.
model Venda {
  id                   String        @id @default(cuid())
  farmaciaId           String
  produtoId            String
  data                 DateTime
  quantidade           Decimal       @db.Decimal(14, 3)
  valorTotal           Decimal       @db.Decimal(14, 2)
  valorUnitario        Decimal?      @db.Decimal(12, 4)
  custoUnitario        Decimal?      @db.Decimal(12, 4)
  tipoVenda            TipoVenda?
  valorComparticipacao Decimal?      @db.Decimal(14, 2)
  valorPagoUtente      Decimal?      @db.Decimal(14, 2)
  numeroTransacoes     Int?
  dataIngestao         DateTime      @default(now())
  loteIngestaoId       String?

  farmacia             Farmacia      @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  produto              Produto       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  loteIngestao         LoteIngestao? @relation(fields: [loteIngestaoId], references: [id])

  @@index([farmaciaId, data])
  @@index([produtoId, data])
  @@index([farmaciaId, produtoId, data])
  @@index([loteIngestaoId])
}

/// Vendas mensais agregadas.
model VendaMensal {
  id               String        @id @default(cuid())
  farmaciaId       String
  produtoId        String
  ano              Int
  mes              Int
  quantidade       Decimal       @db.Decimal(14, 3)
  valorTotal       Decimal       @db.Decimal(14, 2)
  mesCompleto      Boolean       @default(true)
  origemBootstrap  Boolean       @default(false)
  dataAtualizacao  DateTime      @updatedAt
  loteIngestaoId   String?

  farmacia         Farmacia      @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  produto          Produto       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  loteIngestao     LoteIngestao? @relation(fields: [loteIngestaoId], references: [id])

  @@unique([farmaciaId, produtoId, ano, mes])
  @@index([ano, mes])
  @@index([farmaciaId, ano, mes])
  @@index([produtoId, ano, mes])
}

/// Compras diárias agregadas por produto-dia-farmácia-fornecedor.
model Compra {
  id                  String        @id @default(cuid())
  farmaciaId          String
  produtoId           String
  fornecedorId        String?
  data                DateTime
  quantidade          Decimal       @db.Decimal(14, 3)
  valorTotal          Decimal       @db.Decimal(14, 2)
  precoUnitario       Decimal?      @db.Decimal(12, 4)
  descontoBonificacao Decimal?      @db.Decimal(14, 2)
  numeroDocumento     String?
  dataIngestao        DateTime      @default(now())
  loteIngestaoId      String?

  farmacia            Farmacia      @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  produto             Produto       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  fornecedor          Fornecedor?   @relation("CompraFornecedor", fields: [fornecedorId], references: [id])
  loteIngestao        LoteIngestao? @relation(fields: [loteIngestaoId], references: [id])

  @@index([farmaciaId, data])
  @@index([produtoId, data])
  @@index([fornecedorId])
  @@index([farmaciaId, produtoId, data])
  @@index([loteIngestaoId])
}

/// Devoluções diárias.
model Devolucao {
  id                  String         @id @default(cuid())
  farmaciaId          String
  produtoId           String
  data                DateTime
  quantidade          Decimal        @db.Decimal(14, 3)
  valor               Decimal        @db.Decimal(14, 2)
  tipo                TipoDevolucao
  motivo              String?
  fornecedorDestinoId String?
  dataIngestao        DateTime       @default(now())
  loteIngestaoId      String?

  farmacia            Farmacia       @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  produto             Produto        @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  fornecedorDestino   Fornecedor?    @relation("DevolucaoFornecedorDestino", fields: [fornecedorDestinoId], references: [id])
  loteIngestao        LoteIngestao?  @relation(fields: [loteIngestaoId], references: [id])

  @@index([farmaciaId, data])
  @@index([produtoId, data])
  @@index([tipo])
  @@index([fornecedorDestinoId])
  @@index([loteIngestaoId])
}

/// Histórico periódico de stock por produto-farmácia.
model HistoricoStock {
  id              String        @id @default(cuid())
  farmaciaId      String
  produtoId       String
  dataFotografia  DateTime
  quantidade      Decimal       @db.Decimal(14, 3)
  valorCusto      Decimal?      @db.Decimal(14, 2)
  loteIngestaoId  String?

  farmacia        Farmacia      @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  produto         Produto       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  loteIngestao    LoteIngestao? @relation(fields: [loteIngestaoId], references: [id])

  @@unique([farmaciaId, produtoId, dataFotografia])
  @@index([farmaciaId, dataFotografia])
  @@index([produtoId, dataFotografia])
}

//////////////////////////////////////////////////////
// AJUSTES E INVENTÁRIO
//////////////////////////////////////////////////////

/// Ajustes manuais de stock ou correções operacionais.
model AjusteStock {
  id               String         @id @default(cuid())
  farmaciaId       String
  produtoId        String?
  produtoInternoId String?
  data             DateTime
  tipo             TipoAjusteStock
  quantidade       Decimal        @db.Decimal(14, 3)
  valor            Decimal?       @db.Decimal(14, 2)
  motivo           String?
  observacoes      String?
  dataIngestao     DateTime       @default(now())
  loteIngestaoId   String?

  farmacia         Farmacia       @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  produto          Produto?       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoInterno   ProdutoInterno? @relation(fields: [produtoInternoId], references: [id], onDelete: Cascade)
  loteIngestao     LoteIngestao?  @relation(fields: [loteIngestaoId], references: [id])

  @@index([farmaciaId, data])
  @@index([produtoId, data])
  @@index([produtoInternoId, data])
  @@index([tipo])
  @@index([loteIngestaoId])
}

/// Cabeçalho de inventário físico da farmácia.
model Inventario {
  id               String           @id @default(cuid())
  farmaciaId       String
  nome             String?
  dataInventario   DateTime
  estado           EstadoInventario @default(RASCUNHO)
  observacoes      String?
  dataCriacao      DateTime         @default(now())
  dataAtualizacao  DateTime         @updatedAt
  loteIngestaoId   String?

  farmacia         Farmacia         @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  loteIngestao     LoteIngestao?    @relation(fields: [loteIngestaoId], references: [id])
  linhas           LinhaInventario[]

  @@index([farmaciaId, dataInventario])
  @@index([estado])
}

/// Linhas do inventário por produto.
model LinhaInventario {
  id               String         @id @default(cuid())
  inventarioId     String
  produtoId        String?
  produtoInternoId String?
  stockSistema     Decimal?       @db.Decimal(14, 3)
  stockContado     Decimal        @db.Decimal(14, 3)
  diferenca        Decimal?       @db.Decimal(14, 3)
  valorDiferenca   Decimal?       @db.Decimal(14, 2)
  observacoes      String?

  inventario       Inventario     @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  produto          Produto?       @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoInterno   ProdutoInterno? @relation(fields: [produtoInternoId], references: [id], onDelete: Cascade)

  @@index([inventarioId])
  @@index([produtoId])
  @@index([produtoInternoId])
}

//////////////////////////////////////////////////////
// DADOS DERIVADOS / OPERACIONAIS
//////////////////////////////////////////////////////

/// Indicadores pré-calculados por produto-farmácia.
model IndicadoresProdutoFarmacia {
  id                    String               @id @default(cuid())
  produtoId             String
  farmaciaId            String
  mediaVendasDiarias30d Decimal?             @db.Decimal(14, 4)
  mediaVendasDiarias90d Decimal?             @db.Decimal(14, 4)
  mediaVendasMensais3m  Decimal?             @db.Decimal(14, 4)
  mediaVendasMensais12m Decimal?             @db.Decimal(14, 4)
  diasStockRestante     Decimal?             @db.Decimal(14, 2)
  diasSemVenda          Int?
  ultimoPrecoCompra     Decimal?             @db.Decimal(12, 4)
  ultimoFornecedorId    String?
  classificacaoABC      ClassificacaoABC     @default(NAO_CLASSIFICADO)
  classificacaoRotacao  ClassificacaoRotacao @default(NORMAL)
  valorStockParado      Decimal?             @db.Decimal(14, 2)
  dataCalculo           DateTime             @updatedAt

  produto               Produto              @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  farmacia              Farmacia             @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  ultimoFornecedor      Fornecedor?          @relation("IndicadorUltimoFornecedor", fields: [ultimoFornecedorId], references: [id])

  @@unique([produtoId, farmaciaId])
  @@index([farmaciaId])
  @@index([classificacaoRotacao])
  @@index([classificacaoABC])
  @@index([diasSemVenda])
}

/// Lista de encomenda guardada pelo utilizador.
model ListaEncomenda {
  id              String                @id @default(cuid())
  farmaciaId      String
  nome            String
  estado          EstadoListaEncomenda  @default(RASCUNHO)
  /// Sub-estado do fluxo de exportação para SPharm. Aplica-se apenas
  /// quando `estado = FINALIZADA`; em RASCUNHO o valor existe mas não
  /// é consumido pelo agent (o outbox só cria rows para listas
  /// finalizadas via createEncomendaWithOutbox). Default PENDENTE é
  /// seguro porque sem OrderOutbox associado nada é exportado.
  estadoExport    OrderExportState      @default(PENDENTE)
  criadoPorId     String
  dataCriacao     DateTime              @default(now())
  dataAtualizacao DateTime              @updatedAt

  farmacia        Farmacia              @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  criadoPor       Utilizador            @relation(fields: [criadoPorId], references: [id])
  linhas          LinhaEncomenda[]
  outbox          OrderOutbox?

  @@index([farmaciaId])
  @@index([criadoPorId])
  @@index([estado])
  @@index([estadoExport])
}

/// Linhas da lista de encomenda.
model LinhaEncomenda {
  id                   String         @id @default(cuid())
  listaEncomendaId     String
  produtoId            String
  quantidadeSugerida   Decimal?       @db.Decimal(14, 3)
  quantidadeAjustada   Decimal?       @db.Decimal(14, 3)
  fornecedorSugeridoId String?
  notas                String?

  listaEncomenda       ListaEncomenda @relation(fields: [listaEncomendaId], references: [id], onDelete: Cascade)
  produto              Produto        @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  fornecedorSugerido   Fornecedor?    @relation("LinhaEncomendaFornecedorSugerido", fields: [fornecedorSugeridoId], references: [id])

  @@unique([listaEncomendaId, produtoId])
  @@index([produtoId])
  @@index([fornecedorSugeridoId])
}

/// Fila de revisão manual do catálogo.
model FilaRevisao {
  id             String             @id @default(cuid())
  produtoId      String
  tipoRevisao    TipoRevisao
  prioridade     PrioridadeRevisao  @default(MEDIA)
  dadosOrigem    Json?
  estado         EstadoFilaRevisao  @default(PENDENTE)
  dataCriacao    DateTime           @default(now())
  dataResolucao  DateTime?

  produto        Produto            @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([estado, prioridade])
  @@index([produtoId])
  @@index([tipoRevisao])
}

/// Fila técnica para enriquecimento automático.
model EnriquecimentoFila {
  id               String               @id @default(cuid())
  produtoId        String
  prioridade       PrioridadeRevisao    @default(MEDIA)
  ultimaTentativa  DateTime?
  numeroTentativas Int                  @default(0)
  estado           EnriquecimentoEstado @default(PENDENTE)
  ultimaFonte      String?
  mensagemErro     String?
  dataCriacao      DateTime             @default(now())
  dataAtualizacao  DateTime             @updatedAt

  produto          Produto              @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([produtoId])
  @@index([estado, prioridade])
}

//////////////////////////////////////////////////////
// INGESTÃO
//////////////////////////////////////////////////////

/// Registo de cada lote recebido/processado.
model LoteIngestao {
  id                String              @id @default(cuid())
  farmaciaId        String
  tipo              TipoLoteIngestao
  dataReferencia    DateTime
  dataProcessamento DateTime?
  estado            EstadoLoteIngestao  @default(RECEBIDO)
  totalRegistos     Int?
  totalAceites      Int?
  totalRejeitados   Int?
  mensagemErro      String?
  nomeFicheiro      String?
  blobUrl           String?
  hashConteudo      String?
  dataCriacao       DateTime            @default(now())
  dataAtualizacao   DateTime            @updatedAt

  farmacia          Farmacia            @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)

  vendas            Venda[]
  vendasMensais     VendaMensal[]
  compras           Compra[]
  devolucoes        Devolucao[]
  historicoStocks   HistoricoStock[]
  produtosInternos  ProdutoInterno[]
  ajustesStock      AjusteStock[]
  inventarios       Inventario[]

  @@index([farmaciaId, tipo, dataReferencia])
  @@index([estado])
}

//////////////////////////////////////////////////////
// OUTBOX DOWNSTREAM (SPharmMT → SPharm)
//
// Fluxo outbound para exportar listas de encomenda criadas em
// SPharmMT para a base de dados SQL Server da farmácia (SPharm).
// Aplicação do padrão transactional outbox: a linha OrderOutbox é
// criada na MESMA transacção do ListaEncomenda, garantindo que
// nenhuma ordem fica órfã.
//
// O agent Windows (scheduled task --pull-downstream, 5 em 5 min):
//   1. GET /api/outbox/v1/orders/pending → recebe rows já leased
//   2. Escreve cada encomenda no SQL Server SPharm (transacção local)
//   3. POST /orders/{id}/ack com o spharmDocumentId retornado
//   4. Em falha → POST /orders/{id}/nack com retryable=true|false
//
// Idempotência: cada outbox row tem um idempotencyKey determinístico
// derivado de tenantSlug + listaEncomendaId. A estratégia exacta de
// reconhecimento desse key em SPharm fica provisional até recebermos
// o schema real do SPharm — ver doc §4.2 do plano bidireccional.
//////////////////////////////////////////////////////

/// Outbox de exportação de encomendas. 1:1 com ListaEncomenda.
/// Criado na mesma transacção via lib/ingest/orders.ts:createEncomendaWithOutbox.
model OrderOutbox {
  id                String           @id @default(cuid())
  listaEncomendaId  String           @unique
  /// Denormalizado para permitir index (farmaciaId, state) sem join
  /// na query hot-path do agent.
  farmaciaId        String

  /// Snapshot congelado do payload que o agent vai escrever em SPharm.
  /// JSON serializado. IMUTÁVEL — edições à lista após criação do
  /// outbox requerem cancelar+recriar (ver lib/ingest/orders.ts).
  payloadJson       String

  /// Chave determinística: "{tenantSlug}:{listaEncomendaId}". Usada
  /// pelo agent como stamp para idempotência em SPharm. A ferramenta
  /// de stamping em SPharm será decidida quando chegar o schema real.
  idempotencyKey    String           @unique

  /// Hash sha256 do payloadJson. Se o mesmo idempotencyKey alguma vez
  /// aparecer com hash diferente, o agent deve abortar e marcar
  /// FALHADO — defesa contra mutação acidental do payload congelado.
  payloadHash       String

  state             OrderExportState @default(PENDENTE)

  /// Contador de tentativas (incluindo a corrente). Reset a 0 no /retry.
  attemptCount      Int              @default(0)
  /// Próxima janela elegível para o agent claim. now() inicial.
  /// Schedule de retry: 1m · 5m · 30m · 2h · 8h · 24h · então FALHADO.
  nextAttemptAt     DateTime         @default(now())
  lastError         String?
  lastAttemptAt     DateTime?

  // ── Lease ────────────────────────────────────────────────────────
  /// Identificador da instância do agent que reclamou a row.
  /// Null quando não há lease activa.
  leasedBy          String?
  /// TTL da lease. 5 min por defeito — próximo run reclama após isto.
  leasedUntil       DateTime?

  // ── Confirmação ──────────────────────────────────────────────────
  /// Número de documento atribuído por SPharm depois do INSERT.
  /// Preenchido no endpoint /ack.
  spharmDocumentId  String?
  exportedAt        DateTime?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  listaEncomenda    ListaEncomenda   @relation(fields: [listaEncomendaId], references: [id], onDelete: Cascade)
  audits            OrderExportAudit[]

  // Hot path: o agent pede pending rows ordenadas por nextAttemptAt.
  @@index([state, nextAttemptAt])
  // Hot path: admin UI lista por farmácia + estado.
  @@index([farmaciaId, state])
  // Liveness check admin: "qual foi a última tentativa?"
  @@index([lastAttemptAt])
}

/// Histórico imutável de tentativas de exportação. NUNCA apagar linhas.
/// Cada /ack, /nack, /retry e /cancel grava uma row aqui para
/// rastreabilidade operacional. O OrderOutbox guarda apenas o estado
/// corrente; a timeline completa vive aqui.
model OrderExportAudit {
  id             String      @id @default(cuid())
  outboxId       String
  attempt        Int
  at             DateTime    @default(now())
  /// "ATTEMPT" | "SUCCESS" | "FAILURE" | "RETRY_SCHEDULED" |
  /// "GAVE_UP" | "MANUAL_RETRY" | "MANUAL_CANCEL" | "LEASE_CLAIMED" |
  /// "LEASE_RELEASED" | "LEASE_EXPIRED"
  status         String
  message        String?
  httpStatus     Int?
  spharmSqlError String?
  /// ID do utilizador que executou a acção manual, se aplicável.
  /// Null para acções do agent.
  actorId        String?

  outbox         OrderOutbox @relation(fields: [outboxId], references: [id], onDelete: Cascade)

  @@index([outboxId, at])
  @@index([status, at])
}